#!/usr/bin/env bash

DDLIBPATH="${DDLIBPATH:-%DDLIBPATH%}"

hasbin() {
    which "$1" &>/dev/null
}

valid_pythons=(
    # Most recent, most specific, first
    python38
    python3.8
    python37
    python3.7
    python36
    python3.6
    python3
    python
)

for pybin in "${valid_pythons[@]}"; do
    if hasbin "$pybin" ; then
        PYBIN="$pybin"
        break
    fi
done

if [[ -z "$PYBIN" ]]; then
    echo "FATAL: Cannot find a python command to run !"
    exit 1
fi

# Because our default handler package is called "handlers",
#  we need to name the custom one differently, hence "myhandlers"
export PYTHONPATH="${PYTHONPATH}:$HOME/Dedupe/myhandlers"

exec "$PYBIN" "$DDLIBPATH/dedupe/dedupe.py" "$@"
