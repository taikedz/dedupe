#!/usr/bin/env bash

DDLIBPATH="${DDLIBPATH:-%DDLIBPATH%}"

hasbin() {
    which "$1" &>/dev/null
}

for pybin in python3 python34 python35 python36 python37 python38 python; do
    if hasbin "$pybin" ; then
        PYBIN="$pybin"
        break
    fi
done

if [[ -z "$PYBIN" ]]; then
    echo "FATAL: Cannot find a python command to run !"
    exit 1
fi

exec "$PYBIN" "$DDLIBPATH/dedupe/dedupe.py" "$@"
